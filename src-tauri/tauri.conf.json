{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AureliusIDE",
  "version": "0.1.0",
  "identifier": "com.aurelius.ide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aurelius IDE",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "category": "DeveloperTool",
    "shortDescription": "Aurelius IDE",
    "longDescription": "Aurelius IDE is a lightweight Linux-first code editor built with Rust, Tauri, CodeMirror, terminal integration, Git tools and integrated AI.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}